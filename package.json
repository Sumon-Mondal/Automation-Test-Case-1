{
  "name": "automation-test-cases",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node scripts/run-playwright.mjs",
    "test:all": "node scripts/run-playwright.mjs",
    "test:case-1": "node scripts/run-playwright.mjs --suite=test-case-1",
    "test:case-2": "node scripts/run-playwright.mjs --suite=test-case-2",
    "test:case-3": "node scripts/run-playwright.mjs --suite=test-case-3",
    "test:case-4": "node scripts/run-playwright.mjs --suite=test-case-4",
    "test:case-5": "node scripts/run-playwright.mjs --suite=test-case-5",
    "test:case-6": "node scripts/run-playwright.mjs --suite=test-case-6",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "install:browsers": "node node_modules/@playwright/test/cli.js install chromium",
    "test:visible": "node scripts/run-playwright.mjs --visible",
    "test:visible:case-1": "node scripts/run-playwright.mjs --visible --suite=test-case-1",
    "test:visible:case-2": "node scripts/run-playwright.mjs --visible --suite=test-case-2",
    "test:visible:case-3": "node scripts/run-playwright.mjs --visible --suite=test-case-3",
    "test:visible:case-4": "node scripts/run-playwright.mjs --visible --suite=test-case-4",
    "test:visible:case-5": "node scripts/run-playwright.mjs --visible --suite=test-case-5",
    "test:visible:case-6": "node scripts/run-playwright.mjs --visible --suite=test-case-6",
    "test:headed": "node scripts/run-playwright.mjs --visible",
    "test:debug": "node scripts/run-playwright.mjs --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  }
}
