{
  "name": "english-playwright-automation",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:all": "playwright test",
    "test:case-1": "ENGLISH_SUITE=test-case-1 playwright test",
    "test:case-2": "ENGLISH_SUITE=test-case-2 playwright test",
    "test:case-3": "ENGLISH_SUITE=test-case-3 playwright test",
    "test:case-4": "ENGLISH_SUITE=test-case-4 playwright test",
    "test:case-5": "ENGLISH_SUITE=test-case-5 playwright test",
    "test:case-6": "ENGLISH_SUITE=test-case-6 playwright test",
    "typecheck": "tsc --noEmit",
    "test:visible": "PLAYWRIGHT_SLOW_MO_MS=750 STEP_DELAY_MS=1000 playwright test --headed --workers=1",
    "test:visible:case-1": "ENGLISH_SUITE=test-case-1 PLAYWRIGHT_SLOW_MO_MS=750 STEP_DELAY_MS=1000 playwright test --headed --workers=1",
    "test:visible:case-2": "ENGLISH_SUITE=test-case-2 PLAYWRIGHT_SLOW_MO_MS=750 STEP_DELAY_MS=1000 playwright test --headed --workers=1",
    "test:visible:case-3": "ENGLISH_SUITE=test-case-3 PLAYWRIGHT_SLOW_MO_MS=750 STEP_DELAY_MS=1000 playwright test --headed --workers=1",
    "test:visible:case-4": "ENGLISH_SUITE=test-case-4 PLAYWRIGHT_SLOW_MO_MS=750 STEP_DELAY_MS=1000 playwright test --headed --workers=1",
    "test:visible:case-5": "ENGLISH_SUITE=test-case-5 PLAYWRIGHT_SLOW_MO_MS=750 STEP_DELAY_MS=1000 playwright test --headed --workers=1",
    "test:visible:case-6": "ENGLISH_SUITE=test-case-6 PLAYWRIGHT_SLOW_MO_MS=750 STEP_DELAY_MS=1000 playwright test --headed --workers=1",
    "test:headed": "npm run test:visible",
    "test:debug": "PLAYWRIGHT_SLOW_MO_MS=300 STEP_DELAY_MS=400 playwright test --debug --workers=1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  }
}
